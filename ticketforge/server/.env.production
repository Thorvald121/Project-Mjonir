# --- Core service ports ---
PORT=4000

# --- Database & cache ---
# Use your managed Postgres. sslmode=require is common on hosted providers.
DATABASE_URL=postgresql://admin:admin123:5432/ticketforge.local?schema=public&sslmode=require
# Managed Redis with TLS
REDIS_URL=rediss://:YOUR_REDIS_PASSWORD@YOUR_REDIS_HOST:6379

# --- Auth / cookies ---
# Generate a strong secret (>= 32 random bytes). Keep it private.
JWT_SECRET=HeimdallsHorn121!
JWT_TTL=7d
AUTH_COOKIE=token
# In prod behind HTTPS, this MUST be 1 so the cookie is Secure-only.
COOKIE_SECURE=1

# --- Web origin (CORS + links in emails) ---
# Your deployed web URL. If you use a custom domain, set it here.
WEB_ORIGIN=https://app.ticketforge.yourdomain.com

# --- Mail (SMTP) ---
# For Mailgun/SES/SendGrid SMTP, port 587 (STARTTLS) is typical.
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=postmaster@mg.yourdomain.com
SMTP_PASS=YOUR_SMTP_PASSWORD
MAIL_FROM=TicketForge <no-reply@yourdomain.com>
# Domain used to form Reply-To like reply+ticket-<id>@MAIL_REPLY_DOMAIN
MAIL_REPLY_DOMAIN=mail.yourdomain.com

# --- Optional integrations ---
OPENAI_API_KEY=
# If you implement inbound email/webhook verification, put the signing secret here
INBOUND_SIGNING_SECRET=
