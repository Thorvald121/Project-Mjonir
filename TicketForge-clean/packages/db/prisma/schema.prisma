generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  AGENT
  REQUESTER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityType {
  CREATED
  COMMENTED
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNED
  TIME_LOGGED
}

model Organization {
  id                    String   @id @default(cuid())
  name                  String
  domain                String?  @unique
  businessTimezone      String   @default("America/New_York")
  slaFirstResponseMins  Int      @default(60)
  slaResolutionMins     Int      @default(480)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  users    User[]
  contacts Contact[]
  tickets  Ticket[]
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String   @unique
  role           Role     @default(AGENT)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTickets  Ticket[]       @relation("assignedTickets")
  requestedTickets Ticket[]       @relation("requestedTickets")
  comments         TicketComment[]
  activities       TicketActivity[]
  timeEntries      TimeEntry[]
}

model Contact {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  email          String
  company        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets      Ticket[]

  @@unique([organizationId, email])
}

model Ticket {
  id                  String         @id @default(cuid())
  organizationId      String
  requesterId         String?
  contactId           String?
  assigneeId          String?
  ticketNumber        Int
  title               String
  description         String
  status              TicketStatus   @default(OPEN)
  priority            TicketPriority @default(MEDIUM)
  source              String         @default("portal")
  firstResponseDueAt  DateTime?
  resolutionDueAt     DateTime?
  firstRespondedAt    DateTime?
  resolvedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requester    User?           @relation("requestedTickets", fields: [requesterId], references: [id], onDelete: SetNull)
  assignee     User?           @relation("assignedTickets", fields: [assigneeId], references: [id], onDelete: SetNull)
  contact      Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  comments     TicketComment[]
  activities   TicketActivity[]
  timeEntries  TimeEntry[]

  @@unique([organizationId, ticketNumber])
  @@index([organizationId, status])
  @@index([assigneeId])
  @@index([priority])
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   String?
  body       String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket  Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author  User?  @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model TicketActivity {
  id         String       @id @default(cuid())
  ticketId   String
  actorId    String?
  type       ActivityType
  message    String
  metadata   Json?
  createdAt  DateTime     @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorId], references: [id], onDelete: SetNull)
}

model TimeEntry {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  minutes   Int
  notes     String?
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
